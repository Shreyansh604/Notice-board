generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Notice {
  id          Int      @id @default(autoincrement())
  title       String
  body        String   @db.Text
  category    String   // "Exam" | "Event" | "General"
  priority    String   // "Normal" | "Urgent"
  publishDate DateTime
  imageUrl    String?
  createdAt   DateTime @default(now())
}